# ===== Backend (Flask) environment =====
# Copy this file to "backend/.env" and fill in your real values.
# In PowerShell:  Copy-Item backend\.env.example backend\.env

FLASK_ENV=development
FLASK_DEBUG=True

# ----- Required -----
GROQ_API_KEY=
GOOGLE_SHEETS_API_KEY=

# ----- Google Sheets -----
GOOGLE_SHEETS_ID=1PflvP_NfmoVc5b5wBsAIUnM6f6wngqQCt02-uYxEuDk
GOOGLE_SHEETS_TAB=Sheet1

# ----- Firebase Admin (service account) -----
# Easiest: put your service-account JSON somewhere and point to it:
FIREBASE_SERVICE_ACCOUNT_PATH=
# OR provide the individual fields below instead of the path:
FIREBASE_TYPE=service_account
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token

# ----- n8n automation (optional) -----
N8N_BASE_WEBHOOK_URL=
N8N_AGENT_URL=

# ----- Telegram alerts (optional) -----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
